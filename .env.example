# Supabase Project Settings > API. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Public application origin used for Supabase Auth email callbacks.
# Production must use the exact deployed HTTPS origin without a path.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project Settings > API. Server-only and required by Server Actions.
# Never prefix this value with NEXT_PUBLIC_, commit it, or expose it to a browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
