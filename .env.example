# Supabase Project Settings > API. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Supabase Project Settings > API. Server-only and required by Server Actions.
# Never prefix this value with NEXT_PUBLIC_, commit it, or expose it to a browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
